# Database
DATABASE_URL=postgresql+asyncpg://aegis:aegis_password@localhost:5432/aegis_db
DATABASE_URL_SYNC=postgresql://aegis:aegis_password@localhost:5432/aegis_db

# JWT
JWT_SECRET_KEY=your-super-secret-key-change-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60

# LLM Provider (mock | qwen | llama | deepseek)
LLM_PROVIDER=mock

# App
APP_ENV=development
APP_PORT=8000
